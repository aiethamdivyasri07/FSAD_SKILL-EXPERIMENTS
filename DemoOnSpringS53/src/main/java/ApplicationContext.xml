<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans-3.1.xsd
           http://www.springframework.org/schema/context
           http://www.springframework.org/schema/context/spring-context-3.1.xsd">
<!--  create a bean for employees class-->      
<bean id="emp1Bean" class="DemoOnSpring.DemoOnSpringS53.Employees">
<property name="empId" value="1" />
<property name="empName" value="Divya" />
<property name="empSalary" value="9999.95" />
<property name="empActive" value="true" />
 <property name="empList">
 <list>
 <value> Java</value>
 <value> Hibernate</value>
 <value> Spring</value>
 </list>
 </property>
</bean>

<bean id="emp2Bean" class="DemoOnSpring.DemoOnSpringS53.Employees">
<property name="empId" value="2" />
<property name="empName" value="Sri" />
<property name="empSalary" value="6666.65" />
<property name="empActive" value="false" />
 <property name="empList">
 <list>
 <value> AI</value>
 <value> Machine Learning</value>
 <value> Data Science</value>
 </list>
 </property>
</bean>

</beans>